# Official Rubyzip repository
gem 'rubyzip'

# A simple gem for generating string diffs
gem 'differ'

# AWS Lambda Ruby Runtime Interface Client
gem 'aws_lambda_ric'

# A super efficient Amazon SQS thread based message processor for Ruby
gem 'shoryuken'

group :development, :test do
  # Call 'byebug' anywhere in the code to stop execution and get a debugger console
  gem 'byebug', platforms: %I[mri mingw x64_mingw]
  # RSpec for Rails 5+
  gem 'rspec-rails', '~> 4.1.0'
  # Factory Bot ♥ Rails
  gem 'factory_bot_rails'

  # A Ruby gem to load environment variables from `.env`.
  gem 'dotenv-rails'

  ## Generates Brazilian CPF numbers for use in testing.
  gem 'cpf_faker'
  ## A library for generating fake data such as names, addresses, and phone numbers.
  gem 'faker'

  # Library for stubbing and setting expectations on HTTP requests in Ruby.
  gem 'webmock'
end

