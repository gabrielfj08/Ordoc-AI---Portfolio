# A Pure ruby library to merge PDF files, number pages and maybe more...
gem 'combine_pdf'

# mini replacement for RMagick
gem 'mini_magick'

# A Ruby library that encodes QR Codes
gem 'rqrcode', '~> 2.0'

## The official AWS SDK for Ruby.
gem 'aws-sdk-firehose'
