<!doctype html>
<html>
<head>
  <meta charset= 'utf-8' />
  <style>
    div {
      display: inline;
    }
  </style>
</head>
<body style= "font-family: 'Plus Jakarta Sans', sans-serif;">
  <br>
  <div>
    <div style="border: 1px solid #000000; padding: 5px; background-color: #ffffff;">
      <div style="display: inline-block; vertical-align: middle;">
        <img src="https://staging.api.printercloud.com.br/img/flow-logo.svg" alt="logo" width="18"/>
      </div>
      <div style="margin-left: 0.3em;">
        <span style="font-size: 14px;"> 
          Esse documento foi assinado eletrônicamente. Verificação na página de protocolo de assinaturas, ao final do documento. <b>Código de autenticidade:</b> <%= @signature.signable.uuid %>.
        </span>
      </div>
    </div>
  </div>​
</body>
