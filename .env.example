# Example environment configuration for local development and tests
# Copy this file to `.env` and adjust the values before running integration tests

# Default admin credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=adminpass

# Demo user used by integration tests
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=demopass

# Credentials used by test scripts
TEST_AUTH_TOKEN=your_jwt_token
TEST_PASSWORD=demopass
TEST_USER_EMAIL=user@example.com
TEST_USER_PASSWORD=changeme123

# Solr configuration
SOLR_URL=http://localhost:8983/solr
SOLR_COLLECTION=documents
SOLR_USERNAME=
SOLR_PASSWORD=
