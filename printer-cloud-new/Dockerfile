FROM --platform=linux/amd64 node:16.14.0-alpine

WORKDIR /app

COPY ./package* ./

RUN npm install

COPY ./ ./

ARG AWS_ACCESS_KEY_ID
ENV AWS_ACCESS_KEY_ID=$AWS_ACCESS_KEY_ID

ARG AWS_SECRET_ACCESS_KEY
ENV AWS_SECRET_ACCESS_KEY=$AWS_SECRET_ACCESS_KEY

ARG NEXT_PUBLIC_APP_ENV
ENV NEXT_PUBLIC_APP_ENV=$NEXT_PUBLIC_APP_ENV

ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

ARG NEXT_PUBLIC_FLOW_URL
ENV NEXT_PUBLIC_FLOW_URL=$NEXT_PUBLIC_FLOW_URL

ARG NEXT_PUBLIC_RECAPTCHA_SITE_KEY
ENV NEXT_PUBLIC_RECAPTCHA_SITE_KEY=$NEXT_PUBLIC_RECAPTCHA_SITE_KEY

ARG NEXT_PUBLIC_RECAPTCHA_SITE_KEY_INVISIBLE
ENV NEXT_PUBLIC_RECAPTCHA_SITE_KEY_INVISIBLE=$NEXT_PUBLIC_RECAPTCHA_SITE_KEY_INVISIBLE

ARG NEXT_PUBLIC_EXTERNAL_USER_ID
ENV NEXT_PUBLIC_EXTERNAL_USER_ID=$NEXT_PUBLIC_EXTERNAL_USER_ID

ARG RECAPTCHA_SECRET_KEY
ENV RECAPTCHA_SECRET_KEY=$RECAPTCHA_SECRET_KEY

ARG RECAPTCHA_SECRET_KEY_INVISIBLE
ENV RECAPTCHA_SECRET_KEY_INVISIBLE=$RECAPTCHA_SECRET_KEY_INVISIBLE

RUN npm run build

EXPOSE 8080

ENV PORT 8080

CMD ["npm", "start"]
